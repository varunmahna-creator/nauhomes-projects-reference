# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# uploaded images (added per project via admin)
/public/images/projects/
/public/images/testimonials/
/public/images/media/
/public/images/homepage/

# leads data (contains PII)
/data/leads.json

# typescript
*.tsbuildinfo
next-env.d.ts
